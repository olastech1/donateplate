# ============================================================
# ANTIGRAVITY TOOLS — Environment Variables (Stripe + Neon)
# Copy this file to .env and fill in your real values.
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# Neon PostgreSQL (get this from your Neon dashboard)
DATABASE_URL=postgresql://username:password@ep-cool-darkness-1234.us-east-2.aws.neon.tech/antigravity_tools?sslmode=require

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Stripe (fallback — these are used if DB platform_settings are empty)
STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx

# Encryption key for platform_settings table (AES passphrase)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SETTINGS_ENCRYPTION_KEY=your_64_char_hex_key_here

# Frontend URL (for CORS and Stripe redirect URLs)
FRONTEND_URL=http://localhost:3000

# Platform Fee Percentage (default, also configurable in admin UI)
PLATFORM_FEE_PERCENT=2.5
